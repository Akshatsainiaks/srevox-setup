# ═══════════════════════════════════════════════════════
#  Srevox — Self-Hosted Configuration
#  Copy this file to .env and fill in the values below
#  Everything else is pre-configured automatically
# ═══════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here
BACKEND_SECRET_KEY=any_random_32_character_string_here
ENCRYPTION_KEY=exactly_32_characters_here_____

# ── Redirection & Alerts ──────────────────────────────
# The URL of the frontend dashboard (required for Teams/Slack/Email alert buttons to resolve correctly)
FRONTEND_URL=http://localhost:3000

# ── AI Diagnosis (optional) ───────────────────────────
# Get a free key at console.groq.com (recommended)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Or use other providers:
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── Email Alerts (optional) ───────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password

# ── Activity Tracing (optional) ───────────────────────
# ACTIVITY_PORT=5005
# ACTIVITY_SERVICE_URL=http://localhost:5005
